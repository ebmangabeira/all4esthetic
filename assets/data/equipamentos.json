    "espectro_laser": "755nm, 808nm e 1064nm",
    "energia_regulavel": "2 a 95J/cm2 + 2 a 50J/cm2",
    "fonte_alimentacao": "1 fonte de 1000W + 1 fonte de 2000W",
    "refrigeracao": "Cooler e água com sistema ITEC incorporado",
    "corrente_electrica": "100-240VAC, 20A max., 50/60Hz"
  },
